        lines.insert(i+5, "    brain proposal show <id>          查看草稿详情")
        lines.insert(i+6, "    brain proposal approve <id>       审核通过并安装")
        lines.insert(i+7, "    brain proposal reject <id>        驳回草稿")
        break

with open(path, "w", encoding="utf-8") as f:
