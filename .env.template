# 启元智脑 环境变量配置
# 将下面的值替换为真实凭证，然后在启动前执行:
#   PowerShell: $env:BRAIN_FEISHU_WEBHOOK="https://open.feishu.cn/..."
#   或在系统环境变量中永久设置

BRAIN_FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_HOOK_ID
BRAIN_EMAIL_SENDER=your_email@qq.com
BRAIN_EMAIL_PASSWORD=your_auth_code
BRAIN_EMAIL_RECIPIENT=recipient@qq.com