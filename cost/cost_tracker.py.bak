# -*- coding: utf-8 -*-
"""Token cost tracker for DeepSeek API."""
import sqlite3, os, json
from datetime import datetime, timedelta

DB = os.path.join(os.path.dirname(os.path.abspath(__file__)), "cost.db")

PRICE = {
    "deepseek-chat": {"in": 0.14, "out": 0.28},
    "deepseek-reasoner": {"in": 0.55, "out": 2.19},
}

def _db():
    conn = sqlite3.connect(DB)
    conn.execute("""CREATE TABLE IF NOT EXISTS usage_log (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        timestamp TEXT DEFAULT (datetime('now')),
        model TEXT, input_tokens INTEGER DEFAULT 0,
        output_tokens INTEGER DEFAULT 0, cost_usd REAL DEFAULT 0.0,
        source TEXT, project TEXT, notes TEXT
    )""")
    conn.commit()
    return conn

def log(model, inp_tok, out_tok, source="brain", project="", notes=""):
    p = PRICE.get(model, PRICE["deepseek-chat"])
    cost = round((inp_tok * p["in"] + out_tok * p["out"]) / 1000000, 6)
    c = _db()
    c.execute("INSERT INTO usage_log(model,input_tokens,output_tokens,cost_usd,source,project,notes) VALUES(?,?,?,?,?,?,?)", (model, inp_tok, out_tok, cost, source, project, notes))
    c.commit(); c.close()
    return cost

def summary(days=7):
    c = _db()
    since = (datetime.now() - timedelta(days=days)).strftime("%Y-%m-%d")
    r = c.execute("SELECT COUNT(*), COALESCE(SUM(input_tokens),0), COALESCE(SUM(output_tokens),0), COALESCE(SUM(cost_usd),0) FROM usage_log WHERE date(timestamp) >= ?", (since,)).fetchone()
    c.close()
    return dict(calls=r[0], input_tokens=r[1], output_tokens=r[2], total_usd=round(r[3], 4))

def report():
    s7 = summary(7)
    s30 = summary(30)
    return "Token 7d: %d calls, $%.4f | 30d: %d calls, $%.4f" % (s7["calls"], s7["total_usd"], s30["calls"], s30["total_usd"])

if __name__ == "__main__":
    print(report())
